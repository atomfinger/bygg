import testcontainers_gleam/postgres

pub fn main() {
  integration.main()
}


pub fn example_test() {
  use <- integration.guard()
  let assert Ok(_running_pg) =
    postgres.new()
    |> postgres.build()
    |> testcontainers_gleam.start_container()
  Nil
}

