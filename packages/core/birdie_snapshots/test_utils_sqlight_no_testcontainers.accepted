import my_app/context.{type Context, Context}
import sqlight

pub type TestContext {
  TestContext(ctx: Context)
}

pub fn setup() -> TestContext {
  let assert Ok(sqlite) = sqlight.open(":memory:")
  TestContext(ctx: Context(sqlite: sqlite))
}

